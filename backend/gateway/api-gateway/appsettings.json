{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "identidad-autenticacion": {
        "ClusterId": "identidad-cluster",
        "Match": {
          "Path": "/api/autenticacion/{**catch-all}"
        }
      },
      "identidad-usuarios-root": {
        "ClusterId": "identidad-cluster",
        "Match": {
          "Path": "/api/usuarios"
        }
      },
      "identidad-usuarios": {
        "ClusterId": "identidad-cluster",
        "Match": {
          "Path": "/api/usuarios/{**catch-all}"
        }
      },
      "identidad-salud": {
        "ClusterId": "identidad-cluster",
        "Match": {
          "Path": "/api/identidad/salud"
        },
        "Transforms": [
          {
            "PathSet": "/salud"
          }
        ]
      },
      "juegos-trivias": {
        "ClusterId": "juegos-cluster",
        "Match": {
          "Path": "/api/juegos/trivias/{**catch-all}"
        }
      },
      "juegos-trivias-root": {
        "ClusterId": "juegos-cluster",
        "Match": {
          "Path": "/api/juegos/trivias"
        }
      },
      "juegos-busquedas": {
        "ClusterId": "juegos-cluster",
        "Match": {
          "Path": "/api/juegos/busquedas/{**catch-all}"
        }
      },
      "juegos-busquedas-root": {
        "ClusterId": "juegos-cluster",
        "Match": {
          "Path": "/api/juegos/busquedas"
        }
      },
      "juegos-misiones": {
        "ClusterId": "juegos-cluster",
        "Match": {
          "Path": "/api/juegos/misiones/{**catch-all}"
        }
      },
      "juegos-misiones-root": {
        "ClusterId": "juegos-cluster",
        "Match": {
          "Path": "/api/juegos/misiones"
        }
      },
      "juegos-contenidos-activos": {
        "ClusterId": "juegos-cluster",
        "Match": {
          "Path": "/api/juegos/contenidos-activos/{**catch-all}"
        }
      },
      "juegos-salud": {
        "ClusterId": "juegos-cluster",
        "Match": {
          "Path": "/api/juegos/salud"
        },
        "Transforms": [
          {
            "PathSet": "/salud"
          }
        ]
      },
      "sesiones-root": {
        "ClusterId": "sesiones-cluster",
        "Match": {
          "Path": "/api/sesiones"
        }
      },
      "sesiones": {
        "ClusterId": "sesiones-cluster",
        "Match": {
          "Path": "/api/sesiones/{**catch-all}"
        }
      },
      "sesiones-hub-root": {
        "ClusterId": "sesiones-cluster",
        "Match": {
          "Path": "/hubs/sesiones"
        }
      },
      "sesiones-hub": {
        "ClusterId": "sesiones-cluster",
        "Match": {
          "Path": "/hubs/sesiones/{**catch-all}"
        }
      },
      "sesiones-salud": {
        "ClusterId": "sesiones-cluster",
        "Match": {
          "Path": "/api/sesiones/salud"
        },
        "Transforms": [
          {
            "PathSet": "/salud"
          }
        ]
      }
    },
    "Clusters": {
      "identidad-cluster": {
        "Destinations": {
          "identidad-1": {
            "Address": "http://identidad-servicio:8080/"
          }
        }
      },
      "juegos-cluster": {
        "Destinations": {
          "juegos-1": {
            "Address": "http://juegos-servicio:8080/"
          }
        }
      },
      "sesiones-cluster": {
        "Destinations": {
          "sesiones-1": {
            "Address": "http://sesiones-servicio:8080/"
          }
        }
      }
    }
  }
}
