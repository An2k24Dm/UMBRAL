{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "identidad-autenticacion": {
        "ClusterId": "identidad-cluster",
        "Match": {
          "Path": "/api/autenticacion/{**catch-all}"
        }
      },
      "identidad-usuarios-root": {
        "ClusterId": "identidad-cluster",
        "Match": {
          "Path": "/api/usuarios"
        }
      },
      "identidad-usuarios": {
        "ClusterId": "identidad-cluster",
        "Match": {
          "Path": "/api/usuarios/{**catch-all}"
        }
      },
      "identidad-salud": {
        "ClusterId": "identidad-cluster",
        "Match": {
          "Path": "/api/identidad/salud"
        },
        "Transforms": [
          {
            "PathSet": "/salud"
          }
        ]
      }
    },
    "Clusters": {
      "identidad-cluster": {
        "Destinations": {
          "identidad-1": {
            "Address": "http://identidad-servicio:8080/"
          }
        }
      }
    }
  }
}
