# =============================================================================
# UMBRAL — Variables de entorno de referencia.
# Este archivo es informativo: el docker-compose.yml ya las inyecta directamente
# en cada servicio. Cópialo a .env sólo si vas a personalizarlas.
# =============================================================================

# --- PostgreSQL identidad-servicio ---
POSTGRES_USER=umbral
POSTGRES_PASSWORD=umbral123
POSTGRES_DB=umbral_identidad

# --- PostgreSQL Keycloak ---
KC_DB=postgres
KC_DB_URL=jdbc:postgresql://postgres-keycloak:5432/keycloak
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=keycloak123

# --- Keycloak admin ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# --- identidad-servicio: cadena de conexión y Keycloak ---
ConnectionStrings__BaseDatos=Host=postgres-identidad;Port=5432;Database=umbral_identidad;Username=umbral;Password=umbral123
Keycloak__Authority=http://keycloak:8080/realms/umbral
Keycloak__ClientId=umbral-backend
Keycloak__ClientSecret=umbral-backend-secreto

# --- Frontend web ---
VITE_API_URL=http://localhost:5000

# ==========================================================
# SMTP - Correos de UMBRAL
# ==========================================================
# Activa o desactiva el envío real de correos.
# En false, el backend no envía correos.
CORREO_HABILITADO=false

# Para Gmail usar smtp.gmail.com
CORREO_HOST=smtp.gmail.com

# Para Gmail normalmente se usa 587
CORREO_PUERTO=587

# Para Gmail dejar en true
CORREO_USAR_SSL=true

# Cuenta Gmail emisora.
# Recomendado: usar una cuenta exclusiva del sistema, no un correo personal.
CORREO_USUARIO=umbral.sistema@gmail.com

# Contraseña de aplicación de Gmail.
# No colocar la contraseña normal del correo.
# En .env.example dejar vacío o usar un placeholder.
CORREO_CONTRASENA=CAMBIAR_POR_CONTRASENA_DE_APLICACION

# Correo que aparecerá como remitente.
# Recomendado: igual que CORREO_USUARIO.
CORREO_REMITENTE=umbral.sistema@gmail.com

# Nombre visible del remitente.
CORREO_REMITENTE_NOMBRE=UMBRAL